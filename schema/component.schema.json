                      "default": "",
                      "_adapt": {
                        "translatable": true
                      }
                    },
                    "attribution": {
                      "type": "string",
                      "title": "Attribution",
                      "description": "Text to be displayed as an attribution",
                      "default": "",
                      "_adapt": {
                        "translatable": true
                      }
                    }
                  }
                }
              }
            },
            "_incorrectFinal": {
              "type": "object",
              "title": "Incorrect feedback (final attempt)",
