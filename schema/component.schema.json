                },
                "_graphic": {
                  "type": "object",
                  "title": "Graphic",
                  "default": {},
                  "properties": {
                    "_src": {
                      "type": "string",
                      "title": "Source",
                      "default": "",
                      "_backboneForms": {
                        "type": "Asset",
                        "media": "image"
                      }
                    },
                    "alt": {
                      "type": "string",
                      "title": "Alternative text",
